# Dungeon Master Environment Variables
# Copy this file to .env and fill in your values.

# LLM Provider (OpenRouter)
DM_OPENROUTER_API_KEY=your-api-key-here

# Optional: change the LLM model
DM_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional: database path (default is ./dungeon.db)
DM_DATABASE_URL=sqlite:///./dungeon.db
